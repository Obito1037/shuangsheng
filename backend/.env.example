VIVO_APP_ID=your_app_id
VIVO_APP_KEY=your_app_key
DATABASE_URL=sqlite:///./echolearn.db
JWT_SECRET_KEY=change_me_in_local_env
ACCESS_TOKEN_MINUTES=60
REFRESH_TOKEN_DAYS=30
LOCAL_STORAGE_DIR=./storage_data
MAX_UPLOAD_BYTES=52428800
ALLOWED_UPLOAD_EXTENSIONS=.txt,.md,.pdf,.doc,.docx,.ppt,.pptx,.jpg,.jpeg,.png,.webp,.wav,.mp3,.m4a
CORS_ALLOW_ORIGINS=https://appassets.androidplatform.net,https://api.echolearn.cn,http://localhost,http://localhost:5173,http://127.0.0.1,http://127.0.0.1:5173,http://10.0.2.2,http://10.0.2.2:8000
VIVO_BASE_URL=https://api-ai.vivo.com.cn
VIVO_LLM_BASE_URL=https://api-ai.vivo.com.cn/v1
VIVO_LLM_MODEL=Doubao-Seed-2.0-mini
VIVO_LLM_TEXT_MODEL=Doubao-Seed-2.0-mini
VIVO_LLM_STREAM_MODEL=Doubao-Seed-2.0-mini
VIVO_IMAGE_UNDERSTANDING_MODEL=Doubao-Seed-2.0-mini
VIVO_REASONING_MODEL=Doubao-Seed-2.0-mini
VIVO_VISION_MODEL=Volc-DeepSeek-V3.2
VIVO_EMBEDDING_MODEL=m3e-base
VIVO_RERANK_MODEL=bge-reranker-large
HTTP_TIMEOUT_SECONDS=30
HTTP_MAX_RETRIES=2
HTTP_BACKOFF_SECONDS=0.25

EMAIL_ENABLED=false
SMTP_HOST=smtp.163.com
SMTP_PORT=465
SMTP_USE_SSL=true
SMTP_USE_TLS=false
SMTP_USERNAME=your_mailbox@163.com
SMTP_PASSWORD=your_smtp_authorization_code
SMTP_FROM_EMAIL=your_mailbox@163.com
SMTP_FROM_NAME=双生
EMAIL_CODE_EXPIRE_MINUTES=10
EMAIL_CODE_LENGTH=6
